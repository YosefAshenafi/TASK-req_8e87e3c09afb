{
  "name": "secureroom",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit": "vitest run --config unit_tests/vitest.config.ts --coverage",
    "test:api": "vitest run --config API_tests/vitest.config.ts --coverage",
    "test:api:coverage": "vitest run --config API_tests/vitest.config.ts --coverage",
    "test:e2e": "playwright test --config e2e_tests/playwright.config.ts",
    "lint": "ng lint",
    "e2e": "playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,html,scss}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.8",
    "fast-json-patch": "^3.1.1",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "papaparse": "^5.5.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@angular-eslint/schematics": "^21.3.1",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.59.1",
    "@types/papaparse": "^5.5.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.8",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.0",
    "fake-indexeddb": "^4.0.2",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
